# News Intelligence Engine - Environment Variables
# Copy this file to .env and fill in your API keys

# Required: Claude API Key for generating briefings
# Get yours at: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Optional: Serper.dev API Key for Google Search results
# Get yours at: https://serper.dev/
SERPER_API_KEY=your_serper_key_here

# Optional: NewsAPI Key for news articles
# Get yours at: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here
